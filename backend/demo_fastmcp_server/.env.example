# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Server Identity ──────────────────────────────────────────────────────────
SERVER_NAME=TaskHub MCP
# development | staging | production
# development uses StaticTokenVerifier; any other value uses JWTVerifier.
ENVIRONMENT=development

# ─── Transport ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Required when ENVIRONMENT != development.
# Must be ≥ 32 characters for HMAC-SHA256 security.
JWT_SECRET=CHANGE-ME-in-production-must-be-32+-chars!!
JWT_ISSUER=taskhub-auth-service
JWT_AUDIENCE=taskhub-mcp-server

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per client per window.
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_MINUTES=1

# ─── Behaviour ────────────────────────────────────────────────────────────────
# true  → internal error details hidden from LLM clients (recommended for prod)
# false → full error messages forwarded (useful for debugging)
MASK_ERRORS=true

# Hard cap on tool response payload (bytes). Protects LLM context windows.
MAX_RESPONSE_BYTES=500000

# Server-side cursor pagination page size for list operations.
LIST_PAGE_SIZE=50

# ─── Dev Tokens ───────────────────────────────────────────────────────────────
# Plain-string bearer tokens used only when ENVIRONMENT=development.
# Replace these defaults before sharing any .env file with teammates.
DEV_ADMIN_TOKEN=dev-admin-2024
DEV_USER_TOKEN=dev-user-2024
DEV_READONLY_TOKEN=dev-readonly-2024
